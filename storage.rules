rules_version = '2';

// Copiar en Firebase Console > Storage > Reglas
service firebase.storage {
  match /b/{bucket}/o {

    // Imágenes de productos: todos pueden leer, solo autenticados pueden subir
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
