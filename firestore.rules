rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Productos: todos pueden leer (catálogo público), solo usuarios autenticados pueden crear/editar/eliminar (admin)
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Órdenes: cualquiera puede crear (checkout con o sin cuenta), solo autenticados pueden leer (admin)
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
